# Copy this file to .env. Never commit the resulting .env file.
TIMEZONE=Europe/Amsterdam
DB_FILE=multi_site_monitor.db
ACTION_MODE=off
POKEMON_DEBUG_LOGS=0
SNAPSHOT_MODE=changes
PARSER_CONCURRENCY=4
HEARTBEAT_INTERVAL_SECONDS=3600

ENABLE_MEDIAMARKT=false
ENABLE_DREAMLAND=false
ENABLE_BOL=false
ENABLE_POCKETGAMES=false

ENABLE_NOTIFICATIONS=false
ENABLE_HEARTBEAT_ALERTS=true
ENABLE_SUCCESS_ALERTS=true
ENABLE_ERROR_ALERTS=true
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

PROXY_ENABLED=false
PROXY_TYPE=http
PROXY_HOST=
PROXY_PORT=0
PROXY_LOGIN=
PROXY_PASSWORD=

CHROME_BINARY=
CHROME_USER_DATA_DIR=
CHROME_PROFILE_DIR=Default
SELENIUM_TEST_URL=https://www.bol.com/nl/nl/
SELENIUM_PREWARM=false
SELENIUM_PREWARM_ENABLED=false
SELENIUM_PREWARM_ON_RUNTIME_START=false
SELENIUM_KEEP_BROWSER_ALIVE=false
WATCHLIST_WARM_TABS_ENABLED=false
WATCHLIST_WARM_TABS_MAX=6
CHALLENGE_COOLDOWN_BASE_SECONDS=30
CHALLENGE_COOLDOWN_MULTIPLIER=2
CHALLENGE_COOLDOWN_MAX_SECONDS=900
CHALLENGE_COOLDOWN_JITTER_RATIO=0.1
MEDIAMARKT_WARM_TABS_ENABLED=false
BOL_BUY_NOW_URL=https://www.bol.com/nl/nl/checkout/?entryPoint=BUY_NOW

QUEUE_CHECK_ENABLED=true
QUEUE_WAIT_TIMEOUT_SECONDS=300
QUEUE_POLL_SECONDS=1
WORKER_SPEED_PROFILE=balanced
WORKER_TELEGRAM_TRACE_ENABLED=false
WORKER_TELEGRAM_TRACE_LEVEL=normal
WORKER_LOW_LEVEL_DEBUG=false

# These values are write-only in the dashboard API. Prefer a dedicated,
# least-privilege payment method and keep the file ACL restricted to the
# service account.
CHECKOUT_EMAIL=
CHECKOUT_FIRST_NAME=
CHECKOUT_LAST_NAME=
CHECKOUT_STREET=
CHECKOUT_HOUSE_NUMBER=
CHECKOUT_ZIP_CODE=
CHECKOUT_CITY=
CHECKOUT_CARD_NUMBER=
CHECKOUT_CARD_EXPIRY=
CHECKOUT_CARD_CVV=
CHECKOUT_CARD_NAME=

# A legacy .bak is never restored implicitly unless this explicit recovery
# flag is temporarily enabled.
ALLOW_LEGACY_BACKUP_RESTORE=false
